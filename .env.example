# UBI Bot — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Telegram bot token — get one from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID — used for hidden admin commands (/reboot, etc.)
# To find your ID: message @userinfobot on Telegram
ADMIN_TELEGRAM_ID=your_telegram_user_id_here
